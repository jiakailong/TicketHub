# Copying this file as-is is intentionally not enough to start the stack.
# Run scripts/generate-local-env.sh to create random local-development secrets.
TICKETHUB_MYSQL_HOST=127.0.0.1:3306
TICKETHUB_MYSQL_USER=tickethub
TICKETHUB_MYSQL_PASSWORD=REPLACE_WITH_RANDOM_VALUE
TICKETHUB_MYSQL_ROOT_PASSWORD=REPLACE_WITH_RANDOM_VALUE

TICKETHUB_JWT_SECRET=REPLACE_WITH_RANDOM_VALUE
TICKETHUB_ADMIN_MOBILES=
TICKETHUB_PRIVACY_ACTIVE_KEY_VERSION=v1
TICKETHUB_PRIVACY_ENCRYPTION_KEYS=v1:REPLACE_WITH_32_BYTE_BASE64_KEY
TICKETHUB_PRIVACY_LOOKUP_KEY=REPLACE_WITH_32_BYTE_BASE64_KEY

APISIX_ADMIN_KEY=REPLACE_WITH_RANDOM_VALUE
TICKETHUB_GRAFANA_ADMIN_USER=admin
TICKETHUB_GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_RANDOM_VALUE

# Optional WSL override. The launcher detects this automatically in most setups.
# TICKETHUB_HOST_IP=172.20.0.1

